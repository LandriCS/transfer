// ForgotPasswordView.swift
// Forgot password screen — pushed from SignInView
 
import SwiftUI
 
struct ForgotPasswordView: View {
    @Environment(\.dismiss) private var dismiss
 
    @State private var email = ""
    @State private var submitted = false
    @State private var showError = false
 
    let customOrange = Color(red: 178/255, green: 83/255, blue: 12/255)
 
    var body: some View {
        ZStack {
            Color(UIColor.systemGray6)
                .ignoresSafeArea()
 
            VStack(spacing: 0) {
 
                // Logo bar
                HStack {
                    Image(systemName: "cube.fill")
                        .resizable()
                        .scaledToFit()
                        .frame(width: 22, height: 22)
                        .foregroundColor(customOrange)
                    Text("TotalSite")
                        .font(.system(size: 20, weight: .bold))
                        .foregroundColor(.black)
                    Spacer()
                }
                .padding(.horizontal, 24)
                .padding(.vertical, 20)
 
                Spacer()
 
                // Card
                VStack(alignment: .leading, spacing: 20) {
 
                    if submitted {
                        // Confirmation state
                        VStack(alignment: .leading, spacing: 12) {
                            Image(systemName: "envelope.circle.fill")
                                .resizable()
                                .scaledToFit()
                                .frame(width: 48, height: 48)
                                .foregroundColor(customOrange)
 
                            Text("Check your email")
                                .font(.largeTitle)
                                .fontWeight(.bold)
                                .foregroundColor(.black)
 
                            Text("We sent a password reset link to \(email). It may take a minute to arrive.")
                                .font(.subheadline)
                                .foregroundColor(.gray)
                                .fixedSize(horizontal: false, vertical: true)
                        }
 
                        Button(action: { dismiss() }) {
                            Text("Back to sign in")
                                .font(.headline)
                                .foregroundColor(.white)
                                .frame(maxWidth: .infinity)
                                .padding()
                                .background(customOrange)
                                .cornerRadius(8)
                        }
                        .padding(.top, 8)
 
                    } else {
                        // Entry state
                        VStack(alignment: .leading, spacing: 6) {
                            Text("Forgot your password?")
                                .font(.subheadline)
                                .foregroundColor(.gray)
                            Text("Reset password")
                                .font(.largeTitle)
                                .fontWeight(.bold)
                                .foregroundColor(.black)
                        }
 
                        Text("Enter your email and we'll send you a link to reset your password.")
                            .font(.subheadline)
                            .foregroundColor(.gray)
                            .fixedSize(horizontal: false, vertical: true)
 
                        TextField("Email address", text: $email)
                            .padding()
                            .background(Color.white)
                            .cornerRadius(8)
                            .overlay(
                                RoundedRectangle(cornerRadius: 8)
                                    .stroke(Color.gray.opacity(0.25), lineWidth: 1)
                            )
                            .textInputAutocapitalization(.never)
                            .disableAutocorrection(true)
                            .keyboardType(.emailAddress)
 
                        if showError {
                            Text("Please enter a valid email address.")
                                .font(.footnote)
                                .foregroundColor(.red)
                        }
 
                        Button(action: handleResetRequest) {
                            Text("Send reset link")
                                .font(.headline)
                                .foregroundColor(.white)
                                .frame(maxWidth: .infinity)
                                .padding()
                                .background(customOrange)
                                .cornerRadius(8)
                        }
 
                        HStack(spacing: 4) {
                            Spacer()
                            Button(action: { dismiss() }) {
                                Text("← Back to sign in")
                                    .font(.footnote)
                                    .foregroundColor(customOrange)
                                    .fontWeight(.medium)
                            }
                            Spacer()
                        }
                        .padding(.top, 4)
                    }
                }
                .padding(28)
                .background(Color.white)
                .cornerRadius(16)
                .shadow(color: Color.black.opacity(0.07), radius: 12, x: 0, y: 4)
                .padding(.horizontal, 24)
                .frame(maxWidth: 480)
                .animation(.easeInOut(duration: 0.25), value: submitted)
 
                Spacer()
            }
        }
        .navigationBarHidden(true)
    }
 
    // MARK: - Actions
 
    private func handleResetRequest() {
        guard !email.isEmpty, email.contains("@") else {
            showError = true
            return
        }
        showError = false
 
        // TODO: Replace with your real password reset API call
        // On success:
        submitted = true
    }
}
 
#Preview {
    NavigationStack {
        ForgotPasswordView()
    }
}
