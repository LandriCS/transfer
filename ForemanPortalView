// Foreman portal — dashboard with sidebar nav, stats, Open Day CTA, Recent Activity

import SwiftUI

// MARK: - Sample Data Models (replace with real data later)

struct JobLocation: Identifiable, Hashable {
    let id = UUID()
    let name: String
    let jobCode: String
}

// - Foreman Portal

struct ForemanPortalView: View {
    @EnvironmentObject var appState: AppState

    // Selected job location from dropdown
    @State private var selectedLocation: JobLocation = sampleLocations[0]
    @State private var showLocationPicker = false

    // Sidebar selection
    @State private var sidebarSelection: ForemanTab = .dashboard

    // Navigation flags
    @State private var navigateToOpenDay = false

    let customOrange = Color(red: 178/255, green: 83/255, blue: 12/255)

    var body: some View {
        NavigationStack {
            VStack(spacing: 0) {

                // ── Top nav bar ──────────────────────────────────────────
                HStack(spacing: 0) {

                    // TotalSite logo — goes back to HomeView
                    NavigationLink(destination: HomeView()) {
                        HStack(spacing: 7) {
                            Image(systemName: "house.fill")
                                .resizable()
                                .scaledToFit()
                                .frame(width: 20, height: 20)
                                .foregroundColor(customOrange)
                            Text("TotalSite")
                                .font(.system(size: 16, weight: .bold))
                                .foregroundColor(.black)
                        }
                    }
                    .buttonStyle(.plain)

                    // Chevron separator
                    Image(systemName: "chevron.right")
                        .font(.system(size: 11, weight: .semibold))
                        .foregroundColor(.gray)
                        .padding(.horizontal, 8)

                    // Location dropdown
                    Button(action: { showLocationPicker.toggle() }) {
                        HStack(spacing: 5) {
                            Text(selectedLocation.name)
                                .font(.system(size: 14, weight: .medium))
                                .foregroundColor(.black)
                                .lineLimit(1)
                                .truncationMode(.tail)
                                .frame(maxWidth: 200, alignment: .leading)
                            Image(systemName: "chevron.up.chevron.down")
                                .font(.system(size: 11))
                                .foregroundColor(.gray)
                        }
                    }
                    .buttonStyle(.plain)
                    .confirmationDialog("Select Location", isPresented: $showLocationPicker, titleVisibility: .visible) {
                        ForEach(sampleLocations) { loc in
                            Button(loc.name) { selectedLocation = loc }
                        }
                        Button("Cancel", role: .cancel) {}
                    }

                    Spacer()

                    // User name — goes to AccountView
                    NavigationLink(destination: AccountView()) {
                        Text(appState.currentUser?.name ?? "Account")
                            .font(.system(size: 14))
                            .foregroundColor(.black)
                    }
                    .buttonStyle(.plain)
                }
                .padding(.horizontal, 20)
                .padding(.vertical, 14)
                .background(Color.white)
                .overlay(Divider(), alignment: .bottom)

                // ── Main content: sidebar + body ─────────────────────────
                HStack(spacing: 0) {

                    // Sidebar
                    ForemanSidebar(selection: $sidebarSelection)

                    Divider()

                    // Content area
                    Group {
                        switch sidebarSelection {
                        case .dashboard:
                            ForemanDashboardBody(
                                location: selectedLocation,
                                navigateToOpenDay: $navigateToOpenDay
                            )
                        case .tickets:
                            ForemanPlaceholderBody(title: "Tickets")
                        case .crew:
                            ForemanPlaceholderBody(title: "Crew")
                        case .forms:
                            ForemanFormsView()
                        case .profile:
                            ForemanPlaceholderBody(title: "Profile")
                        }
                    }
                    .frame(maxWidth: .infinity, maxHeight: .infinity)
                }
            }
            // Navigate into Open Day portal when button is tapped
            .navigationDestination(isPresented: $navigateToOpenDay) {
                OpenDayView(location: selectedLocation)
            }
            .navigationBarHidden(true)
        }
    }
}

// MARK: - Sidebar Tabs

enum ForemanTab: String, CaseIterable {
    case dashboard = "Dashboard"
    case tickets   = "Tickets"
    case crew      = "Crew"
    case forms     = "Forms"
    case profile   = "Profile"

    var icon: String {
        switch self {
        case .dashboard: return "square.grid.2x2"
        case .tickets:   return "ticket"
        case .crew:      return "person.3"
        case .forms:     return "doc.text"
        case .profile:   return "person.circle"
        }
    }
}

struct ForemanSidebar: View {
    @Binding var selection: ForemanTab

    var body: some View {
        VStack(alignment: .leading, spacing: 4) {
            ForEach(ForemanTab.allCases, id: \.self) { tab in
                Button(action: { selection = tab }) {
                    HStack(spacing: 10) {
                        Image(systemName: tab.icon)
                            .frame(width: 18)
                        Text(tab.rawValue)
                            .font(.system(size: 15))
                    }
                    .foregroundColor(selection == tab ? .black : .gray)
                    .fontWeight(selection == tab ? .semibold : .regular)
                    .padding(.vertical, 10)
                    .padding(.horizontal, 16)
                    .frame(maxWidth: .infinity, alignment: .leading)
                    .background(
                        RoundedRectangle(cornerRadius: 8)
                            .fill(selection == tab ? Color(UIColor.systemGray5) : Color.clear)
                    )
                }
                .buttonStyle(.plain)
            }
            Spacer()
        }
        .padding(.top, 16)
        .padding(.horizontal, 8)
        .frame(width: 200)
        .background(Color(UIColor.systemGray6))
    }
}

// MARK: - Dashboard body

